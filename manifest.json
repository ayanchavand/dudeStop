{
  "manifest_version": 3,
  "name": "DudeStop",
  "version": "1.1",
  "description": "Pause before accessing distracting websites — are you sure this is how you want to spend your time?",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["interstitial.html", "interstitial.js", "blocked.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "options.html",
  "icons": {
  "16": "icon.png",
  "32": "icon.png",
  "48": "icon.png",
  "128": "icon.png"
},
  "action": {
    "default_title": "DudeStop",
    "default_popup": "popup.html"
  }
}
